<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>

    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <nav>
        <h1>TO DO WEEK LIST</h1>
    </nav>

    <form action="/addTodo" method="POST">
        <input type="text" placeholder="TO DO" name="todo">
        <select name="day">
            <option>Monday</option>
            <option>Tuesday</option>
            <option>Wednesday</option>
            <option>Thursday</option>
            <option>Friday</option>
            <option>Saturday</option>
            <option>Sunday</option>
        </select>
        <button>Submit</button>
    </form>

    <section class="monday weekday">
        <h1>Monday</h1>
        <ul>
            <% for (let i = 0; i < info.length; i++) { %>
                <% if (info[i].day === 'Monday' && info[i].complete === true) {%>
                    <li>
                        <span class="todo Monday complete"><%= info[i].todo %></span>
                        <span class="delete">delete</span>
                    </li>
                <% } else if (info[i].day === 'Monday') { %>
                    <li>
                        <span class="todo Monday"><%= info[i].todo %></span>
                        <span class="delete">delete</span>
                    </li>
                <% } %>
            <% } %>
        </ul>    
    </section>

